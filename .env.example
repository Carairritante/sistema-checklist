# ──────────────────────────────────────────────────────────
# WhatsChecklist — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ──────────────────────────────────────────────────────────

# ── Next.js (checklist-app) ────────────────────────────────

# Supabase — encontre em: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Service Role Key — use APENAS no servidor (nunca exponha no cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# URL do serviço WhatsApp (whatsapp-server) — no Render será algo como:
# https://whatsapp-service.onrender.com
WHATSAPP_SERVICE_URL=http://localhost:3001

# ── whatsapp-server/ (serviço separado) ───────────────────
# Copie estas para o .env do whatsapp-server ou configure no Render

SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# (mesma SUPABASE_SERVICE_ROLE_KEY acima)

# ── GitHub Actions Secrets (configurar no repositório GitHub) ──
# RENDER_APP_URL=https://checklist-app.onrender.com
# WHATSAPP_SERVICE_URL=https://whatsapp-service.onrender.com
